# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIGURATION
FIREBASE_DB_URL=https://your-firebase-rtdb.firebaseio.com/
FIREBASE_API_KEY=your_firebase_api_key_or_secret
FIREBASE_PROJECT_ID=your_firebase_project_id

# GMAIL SMTP CONFIGURATION
SENDER_GMAIL_ADDRESS=your_sender_email@gmail.com
SENDER_GMAIL_PASSWORD=your_gmail_app_password

# WEB CONFIRMATION ACTION LINK
WEB_CONFIRM_URL=http://your-dev-domain.app/
